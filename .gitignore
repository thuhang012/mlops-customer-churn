# =========================
# ENVIRONMENT & SYSTEM
# =========================
venv/
.env
__pycache__/
*.pyc
.DS_Store
Thumbs.db
*.log

# =========================
# DATA (DVC-managed)
# =========================
data/raw/*
data/processed/*
data/external/*

# keep structure & dvc
!data/**/.gitkeep
!data/**/*.dvc
!*.dvc
!.dvcignore

# =========================
# ARTIFACTS (models, preprocessors)
# =========================
artifacts/models/*.pkl
!artifacts/models/*.yaml

# keep folder structure
!artifacts/models/
!artifacts/models/.gitkeep

artifacts/tmp/
catboost_info/

# =========================
# MODEL FILES
# =========================
*.pkl
*.joblib

# =========================
# MLFLOW
# =========================

mlartifacts/
mlflow.db
mlflowdb/

# =========================
# NOTEBOOK
# =========================
.ipynb_checkpoints/

monitoring/inference/*
!monitoring/inference/.gitkeep
artifacts/mlruns/

# =========================
# INTERNAL DOCUMENTATION
# =========================
# Keep canonical docs (README*.md), ignore internal working notes.
PROJECT_PROGRESS.md
LOCAL_TESTING.md
