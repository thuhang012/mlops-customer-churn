# ============================================================
# DAGSHUB & DVC CONFIGURATION (FOR AUTOMATED BOOTSTRAP)
# ============================================================
# Copy file này thành file '.env', điền các thông tin dưới
# và chạy lệnh: docker-compose up -d --build
# Tên đăng nhập DagsHub (Ví dụ: bich-le)
DAGSHUB_USER=<your-dagshub-username>

# Token của bạn (Lấy tại: DagsHub > Settings > Tokens)
DAGSHUB_TOKEN=<your-dagshub-token>


