{
  "id": null,
  "uid": "drift-monitoring",
  "title": "Customer Churn Monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RPS",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(api_requests_total{endpoint=~\"/predict|/batch-predict\"}[5m]))", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 8},
              {"color": "green", "value": 15}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 Lat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(api_request_latency_seconds_bucket{endpoint=~\"/predict|/batch-predict\"}[5m])))", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.35},
              {"color": "red", "value": 0.6}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error %",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "(sum(rate(api_requests_total{endpoint=~\"/predict|/batch-predict\",status_class=\"5xx\"}[5m])) or vector(0)) / clamp_min((sum(rate(api_requests_total{endpoint=~\"/predict|/batch-predict\"}[5m])) or vector(0)), 0.001)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.025},
              {"color": "red", "value": 0.04}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Drift",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "drift_features_alert_fraction", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.2},
              {"color": "red", "value": 0.3}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Predictions / sec",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 4},
      "targets": [{"expr": "sum(rate(api_model_predictions_total[5m]))", "refId": "A", "legendFormat": "Pred/s"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(api_request_latency_seconds_bucket{endpoint=~\"/predict|/batch-predict\"}[5m])))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(api_request_latency_seconds_bucket{endpoint=~\"/predict|/batch-predict\"}[5m])))", "refId": "B", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(api_request_latency_seconds_bucket{endpoint=~\"/predict|/batch-predict\"}[5m])))", "refId": "C", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Feature Drift Scores (High to Low)",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 4},
      "targets": [
        {
          "expr": "sort_desc(max without(instance, job) (drift_feature_score{metric=\"$drift_metric\"}))",
          "refId": "A",
          "legendFormat": "{{feature}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.1},
              {"color": "red", "value": 0.2}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true
      }
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Prediction Distribution (Last 1h)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 11},
      "targets": [
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.05\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.0\"}[1h]))", "refId": "A", "legendFormat": "0-0.05", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.1\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.05\"}[1h]))", "refId": "B", "legendFormat": "0.05-0.1", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.2\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.1\"}[1h]))", "refId": "C", "legendFormat": "0.1-0.2", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.3\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.2\"}[1h]))", "refId": "D", "legendFormat": "0.2-0.3", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.4\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.3\"}[1h]))", "refId": "E", "legendFormat": "0.3-0.4", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.5\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.4\"}[1h]))", "refId": "F", "legendFormat": "0.4-0.5", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.6\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.5\"}[1h]))", "refId": "G", "legendFormat": "0.5-0.6", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.7\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.6\"}[1h]))", "refId": "H", "legendFormat": "0.6-0.7", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.8\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.7\"}[1h]))", "refId": "I", "legendFormat": "0.7-0.8", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.9\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.8\"}[1h]))", "refId": "J", "legendFormat": "0.8-0.9", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"0.95\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.9\"}[1h]))", "refId": "K", "legendFormat": "0.9-0.95", "instant": true},
        {"expr": "sum(increase(api_model_prediction_probability_bucket{le=\"1.0\"}[1h])) - sum(increase(api_model_prediction_probability_bucket{le=\"0.95\"}[1h]))", "refId": "L", "legendFormat": "0.95-1.0", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Rate & Alerts",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 11},
      "targets": [
        {"expr": "(sum(rate(api_requests_total{endpoint=~\"/predict|/batch-predict\",status_class=\"5xx\"}[5m])) or vector(0)) / clamp_min((sum(rate(api_requests_total{endpoint=~\"/predict|/batch-predict\"}[5m])) or vector(0)), 0.001)", "refId": "A", "legendFormat": "Error %"},
        {"expr": "0.04", "refId": "B", "legendFormat": "Critical Threshold"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.025},
              {"color": "red", "value": 0.04}
            ]
          }
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Data Freshness Lag (seconds)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "targets": [
        {"expr": "max without(instance, job) (dq_freshness_lag_seconds)", "refId": "A", "legendFormat": "Lag"},
        {"expr": "max without(instance, job) (dq_threshold_freshness_lag_seconds)", "refId": "B", "legendFormat": "Threshold"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Model Quality Overview",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "targets": [
        {"expr": "max without(instance, job) (model_prediction_positive_rate)", "refId": "A", "legendFormat": "Positive Rate"},
        {"expr": "max without(instance, job) (model_low_confidence_fraction)", "refId": "B", "legendFormat": "Low Confidence"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Selected Drift Max vs Threshold",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 27},
      "targets": [
        {
          "expr": "max without(feature, feature_type, instance, job) (drift_feature_score{metric=\"$drift_metric\"})",
          "refId": "A",
          "legendFormat": "Selected Max"
        },
        {
          "expr": "max without(instance, job) (drift_threshold_by_metric{metric=\"$drift_metric\"})",
          "refId": "B",
          "legendFormat": "Selected Threshold"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 13,
      "type": "alertlist",
      "title": "Active Alerts",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 35},
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "maxItems": 50,
        "sortOrder": 1,
        "show": "current"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "drift_metric",
        "type": "custom",
        "label": "Drift Metric",
        "query": "ks,js,psi",
        "current": {"text": "js", "value": "js"},
        "includeAll": false,
        "multi": false,
        "options": [
          {"text": "ks", "value": "ks", "selected": false},
          {"text": "js", "value": "js", "selected": true},
          {"text": "psi", "value": "psi", "selected": false}
        ]
      }
    ]
  },
  "annotations": {"list": []}
}
